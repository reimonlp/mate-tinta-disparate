---
import AdminLayout from '../../layouts/AdminLayout.astro';
import StatCard from '../../components/admin/StatCard.astro';
import PhotoManager from '../../components/admin/PhotoManager.astro';
import ComunidadTab from '../../components/admin/ComunidadTab.astro';
import EncuentrosTab from '../../components/admin/EncuentrosTab.astro';
import DudasTab from '../../components/admin/DudasTab.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

// Obtener datos reales
const dudas = await getCollection('dudas');
const encuentros = await getCollection('encuentros');
const comunidad = await getCollection('comunidad');

const photosDir = path.join(process.cwd(), 'public/photos');
let photos: string[] = [];
if (fs.existsSync(photosDir)) {
  const files = fs.readdirSync(photosDir);
  photos = files.filter(file => /\.(jpg|jpeg|png|webp|gif)$/i.test(file));
}

const stats = [
  { label: 'Fotos en Galería', count: photos.length, icon: '<svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>', color: '#3b82f6' },
  { label: 'Reseñas', count: comunidad.length, icon: '<svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>', color: '#10b981' },
  { label: 'Sedes & Fechas', count: encuentros.length, icon: '<svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>', color: '#f59e0b' },
  { label: 'Dudas (FAQ)', count: dudas.length, icon: '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>', color: '#8b5cf6' },
];
---

<AdminLayout title="Dashboard">
  <header style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
    <div>
      <h1 class="page-title">Administración del Sitio</h1>
      <p class="page-description">Gestioná todo el contenido de la web desde este panel.</p>
    </div>
  </header>

  <div class="tabs">
    <button class="tab-btn active" data-target="dashboard">Resumen</button>
    <button class="tab-btn" data-target="fotos">Fotos</button>
    <button class="tab-btn" data-target="comunidad">Reseñas</button>
    <button class="tab-btn" data-target="encuentros">Sedes</button>
    <button class="tab-btn" data-target="dudas">Dudas (FAQ)</button>
  </div>

  <!-- DASHBOARD TAB -->
  <section id="dashboard" class="tab-content active">
    <div class="stats-grid">
      {stats.map(stat => (
        <StatCard {...stat} />
      ))}
    </div>

    <div class="quick-actions">
      <h2>Acciones Rápidas</h2>
      <div class="actions-grid">
        <button class="action-btn" onclick="document.querySelector('.tab-btn[data-target=\'fotos\']').click(); setTimeout(() => document.getElementById('btn-add-photo').click(), 100)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
          Subir Foto Nueva
        </button>
        <button class="action-btn" onclick="document.querySelector('.tab-btn[data-target=\'comunidad\']').click(); setTimeout(() => document.getElementById('btn-add-comunidad').click(), 100)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
          Añadir Reseña
        </button>
      </div>
    </div>
  </section>

  <PhotoManager photos={photos} />
  <ComunidadTab comunidad={comunidad} />
  <EncuentrosTab encuentros={encuentros} />
  <DudasTab dudas={dudas} />
</AdminLayout>

<script is:inline>
  // Tab Switching Logic
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');

  // Load last active tab
  const activeTab = localStorage.getItem('adminActiveTab') || 'dashboard';
  document.querySelector(`.tab-btn[data-target="${activeTab}"]`)?.click();

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target;
      
      tabBtns.forEach(b => b.classList.remove('active'));
      tabContents.forEach(c => c.classList.remove('active'));
      
      btn.classList.add('active');
      document.getElementById(target)?.classList.add('active');
      localStorage.setItem('adminActiveTab', target);
    });
  });

  // Global delete logic
  window.deleteItem = async (collection, id) => {
    if (!confirm('¿Seguro que querés eliminar este item?')) return;
    
    window.showToast('Eliminando...');

    const response = await fetch(`/api/${collection}`, {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id })
    });

    if (response.ok) {
      window.showToast('Eliminado con éxito');
      // Encontrar y remover el elemento del DOM
      const btn = document.querySelector(`button[data-id="${id}"], button[onclick*="${id}"]`);
      if (btn) {
        const row = btn.closest('tr') || btn.closest('.photo-card');
        if (row) row.remove();
      }
    } else {
      window.showToast('Error al eliminar', true);
    }
  };

  // Close modals clicking outside
  window.onclick = function(event) {
    if (event.target.classList.contains('modal')) {
      event.target.style.display = 'none';
    }
  }
</script>

<style>
  /* Base styles for the admin panel */
  .page-title { font-size: 1.875rem; font-weight: 700; color: #111827; margin-bottom: 0.5rem; }
  .page-description { color: #6b7280; margin-bottom: 2rem; }

  .tabs { display: flex; gap: 0.5rem; margin-bottom: 2rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 0.5rem; overflow-x: auto; }
  .tab-btn { padding: 0.625rem 1.25rem; border-radius: 8px; border: none; background: none; color: #6b7280; font-weight: 500; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
  .tab-btn:hover { background-color: #f3f4f6; color: #374151; }
  .tab-btn.active { background-color: #eff6ff; color: #2563eb; }

  .tab-content { display: none; animation: fadeIn 0.3s ease-out; }
  .tab-content.active { display: block; }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }

  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin-bottom: 2.5rem; }

  .quick-actions { background: white; padding: 1.5rem; border-radius: 12px; border: 1px solid #e5e7eb; }
  .quick-actions h2 { font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem; }
  .actions-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }

  .action-btn { display: flex; align-items: center; justify-content: center; gap: 0.75rem; padding: 0.75rem; background-color: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; font-weight: 500; color: #374151; cursor: pointer; transition: all 0.2s; }
  .action-btn:hover { background-color: #f3f4f6; border-color: #d1d5db; }
  .action-btn svg { width: 1.25rem; height: 1.25rem; }

  /* Section styles used across tabs */
  :global(.section-header) { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  :global(.section-header h2) { font-size: 1.25rem; font-weight: 600; }

  :global(.table-container) { background: white; border-radius: 12px; border: 1px solid #e5e7eb; overflow: hidden; }
  :global(table) { width: 100%; border-collapse: collapse; text-align: left; }
  :global(th) { background-color: #f9fafb; padding: 0.75rem 1.5rem; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: #6b7280; border-bottom: 1px solid #e5e7eb; }
  :global(td) { padding: 1rem 1.5rem; border-bottom: 1px solid #f3f4f6; font-size: 0.875rem; color: #374151; }
  :global(.truncate) { max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  :global(.actions-cell) { display: flex; gap: 0.5rem; }
  :global(.btn-edit), :global(.btn-danger), :global(.btn-primary) { padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.875rem; font-weight: 500; cursor: pointer; border: none; transition: all 0.2s; }
  :global(.btn-primary) { background-color: #2563eb; color: white; }
  :global(.btn-primary:hover) { background-color: #1d4ed8; }
  :global(.btn-edit) { background-color: #f3f4f6; color: #374151; }
  :global(.btn-edit:hover) { background-color: #e5e7eb; }
  :global(.btn-danger) { background-color: #fee2e2; color: #dc2626; }
  :global(.btn-danger:hover) { background-color: #fecaca; }

  :global(.photos-grid) { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.5rem; }
  :global(.photo-card) { background: white; border-radius: 12px; border: 1px solid #e5e7eb; overflow: hidden; }
  :global(.photo-card img) { width: 100%; aspect-ratio: 1; object-fit: cover; border-bottom: 1px solid #e5e7eb; }
  :global(.photo-actions) { padding: 0.75rem; display: flex; justify-content: center; }

  :global(.form-group) { margin-bottom: 1.25rem; }
  :global(.form-group label) { display: block; font-size: 0.875rem; font-weight: 500; color: #374151; margin-bottom: 0.5rem; }
  :global(.form-control) { width: 100%; padding: 0.625rem; border-radius: 8px; border: 1px solid #d1d5db; font-size: 0.875rem; transition: border-color 0.2s; }
  :global(.form-control:focus) { outline: none; border-color: #2563eb; ring: 2px solid #bfdbfe; }
</style>
